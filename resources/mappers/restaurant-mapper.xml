<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
<mapper namespace="restaurant-mapper">
<select id="selectAllRestaurant" resultType="restaurant">
    SELECT
	    REST_NO
	    ,REST_NAME
	    ,CATEGORY
	    ,MIN_PRICE
	    ,DELIVERY_FEE
    FROM
   	 	RESTAURANT
</select>
<select id="selectByCategory" resultType="restaurant">
  	SELECT 
  		REST_NO
	    ,REST_NAME
	    ,CATEGORY
	    ,MIN_PRICE
	    ,DELIVERY_FEE 
	FROM
    	RESTAURANT
    WHERE
    	1=1
  <if test="category != null and category !=''">
    And
    	CATEGORY = #{category}
  </if>
</select>
<select id="selectAllRestaurantProxy" resultType="restaurant">
    SELECT
	    REST_NO
	    ,REST_NAME
	    ,CATEGORY
	    ,MIN_PRICE
	    ,DELIVERY_FEE
    FROM
   	 	RESTAURANT
</select>
<select id="selectDetail" resultType="menu">
    SELECT
	    MENU_NO
	    ,MENU_NAME
	    ,REST_NO
	    ,PRICE,
	CASE 
    	WHEN SOLD_OUT = 'Y' THEN 1
    	ELSE 0 
    	END AS SOLD_OUT_NOW
    FROM
   	 	MENU
   	WHERE
   	 	REST_NO = #{restNo}
</select>
</mapper>